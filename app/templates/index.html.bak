<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Эмулятор IP камер для тестирования NVR</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.5.4/socket.io.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            text-align: center;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.95;
        }

        .status-bar {
            background: #f8f9fa;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #e9ecef;
            flex-wrap: wrap;
            gap: 15px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .status-label {
            font-weight: 600;
            color: #495057;
        }

        .status-value {
            background: #e9ecef;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9em;
        }

        .status-value.running {
            background: #d4edda;
            color: #155724;
        }

        .main-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            padding: 30px;
            background: #f8f9fa;
        }

        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }

        .panel h2 {
            color: #495057;
            margin-bottom: 20px;
            font-size: 1.5em;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .video-list {
            max-height: 300px;
            overflow-y: auto;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .video-item {
            padding: 12px 15px;
            border-bottom: 1px solid #e9ecef;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .video-item:last-child {
            border-bottom: none;
        }

        .video-item:hover {
            background: #f1f3f5;
        }

        .video-item.selected {
            background: #667eea;
            color: white;
        }

        .video-item.selected .video-size {
            color: rgba(255,255,255,0.9);
        }

        .video-name {
            font-weight: 500;
        }

        .video-size {
            font-size: 0.85em;
            color: #868e96;
        }

        .upload-area {
            border: 2px dashed #ced4da;
            border-radius: 10px;
            padding: 30px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 20px;
        }

        .upload-area:hover {
            border-color: #667eea;
            background: #f1f3f5;
        }

        .upload-area i {
            font-size: 3em;
            color: #667eea;
            margin-bottom: 10px;
            display: block;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #495057;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 10px;
            font-size: 1em;
            transition: all 0.3s;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn {
            padding: 12px 25px;
            border: none;
            border-radius: 10px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            width: 100%;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102,126,234,0.3);
        }

        .btn-secondary {
            background: #e9ecef;
            color: #495057;
        }

        .btn-secondary:hover {
            background: #dee2e6;
        }

        .btn-sm {
            padding: 8px 15px;
            font-size: 0.9em;
        }

        .btn-danger {
            background: #dc3545;
            color: white;
        }

        .btn-danger:hover {
            background: #c82333;
        }

        .btn-success {
            background: #28a745;
            color: white;
        }

        .btn-success:hover {
            background: #218838;
        }

        /* Сетка для камер - по 2 в ряд */
        .cameras-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            padding: 20px;
        }

        /* Для мобильных - по 1 в ряд */
        @media (max-width: 768px) {
            .cameras-grid {
                grid-template-columns: 1fr;
            }
        }

        .camera-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transition: all 0.3s;
            border: 1px solid #e9ecef;
            display: flex;
            flex-direction: column;
        }

        .camera-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

        .camera-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e9ecef;
        }

        .camera-name {
            font-size: 1.2em;
            font-weight: 600;
            color: #495057;
        }

        .camera-status {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
        }

        .status-created {
            background: #e9ecef;
            color: #495057;
        }

        .status-running {
            background: #d4edda;
            color: #155724;
        }

        .status-stopped {
            background: #f8d7da;
            color: #721c24;
        }

        /* Контейнер для превью */
        .preview-container {
            width: 100%;
            background: #000;
            border-radius: 10px;
            margin-bottom: 15px;
            overflow: hidden;
            position: relative;
        }

        .preview-container img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 10px;
            border: 2px solid #667eea;
        }

        .live-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(255, 0, 0, 0.8);
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .live-badge::before {
            content: "";
            width: 10px;
            height: 10px;
            background: white;
            border-radius: 50%;
            animation: pulse 1s infinite;
        }

        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }

        .stream-info {
            color: #0f0;
            font-size: 12px;
            margin-top: 5px;
            text-align: center;
            background: rgba(0,0,0,0.7);
            padding: 5px;
            border-radius: 5px;
        }

        .camera-details {
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 0.95em;
        }

        .detail-label {
            color: #868e96;
        }

        .detail-value {
            font-weight: 600;
            color: #495057;
        }

        .camera-actions {
            display: flex;
            gap: 10px;
            margin-top: auto;
        }

        .camera-actions button {
            flex: 1;
        }

        .url-box {
            background: #e8f4f8;
            padding: 10px;
            border-radius: 8px;
            font-size: 0.85em;
            word-break: break-all;
            border: 1px solid #b8d9e5;
            margin-bottom: 15px;
        }

        .url-box strong {
            color: #0066cc;
        }

        .hidden {
            display: none;
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 25px;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            z-index: 1000;
            animation: slideIn 0.3s ease;
        }

        .notification.success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        }

        .notification.error {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        }

        .notification.info {
            background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📹 Эмулятор IP камер для NVR</h1>
            <p>Эмуляция реальных камер с ONVIF и RTSP поддержкой</p>
        </div>

        <div class="status-bar" id="statusBar">
            <div class="status-item">
                <span class="status-label">Статус:</span>
                <span class="status-value running" id="serverStatus">Загрузка...</span>
            </div>
            <div class="status-item">
                <span class="status-label">Версия:</span>
                <span class="status-value" id="serverVersion">0.4</span>
            </div>
            <div class="status-item">
                <span class="status-label">Активных камер:</span>
                <span class="status-value" id="camerasCount">0</span>
            </div>
            <div class="status-item">
                <span class="status-label">Видеофайлов:</span>
                <span class="status-value" id="videosCount">0</span>
            </div>
        </div>

        <div class="main-content">
            <!-- Левая панель - Видеофайлы -->
            <div class="panel">
                <h2>📁 Видеофайлы</h2>
                
                <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                    <div style="font-size: 3em; margin-bottom: 10px;">📤</div>
                    <h3>Загрузить видео</h3>
                    <p>Нажмите для выбора файла (MP4, AVI, MOV)</p>
                    <input type="file" id="fileInput" accept="video/*" style="display: none" onchange="uploadVideo(this)">
                </div>

                <div style="margin-bottom: 15px;">
                    <input type="text" id="videoSearch" placeholder="🔍 Поиск видео..." style="width: 100%; padding: 10px; border: 2px solid #e9ecef; border-radius: 10px;">
                </div>

                <div class="video-list" id="videoList">
                    <div style="text-align: center; padding: 20px; color: #868e96;">
                        Загрузка списка видео...
                    </div>
                </div>
            </div>

            <!-- Правая панель - Создание камеры -->
            <div class="panel">
                <h2>⚙️ Создать новую камеру</h2>

                <div class="form-group">
                    <label>Название камеры:</label>
                    <input type="text" id="cameraName" value="Тестовая камера" placeholder="Например: Вход, Parking, Office">
                </div>

                <div class="form-group">
                    <label>Видеофайл:</label>
                    <select id="videoSelect">
                        <option value="">Выберите видеофайл</option>
                    </select>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>RTSP порт:</label>
                        <input type="number" id="rtspPort" value="8554" min="1024" max="65535">
                    </div>
                    <div class="form-group">
                        <label>ONVIF порт:</label>
                        <input type="number" id="onvifPort" value="8080" min="1024" max="65535">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Логин:</label>
                        <input type="text" id="username" value="admin">
                    </div>
                    <div class="form-group">
                        <label>Пароль:</label>
                        <input type="text" id="password" value="admin123">
                    </div>
                </div>

                <button class="btn btn-primary" onclick="createCamera()">➕ Создать камеру</button>
            </div>
        </div>

        <!-- Список камер (по 2 в ряд) -->
        <h2 style="padding: 0 30px; color: #495057; margin-top: 20px;">🎥 Активные камеры</h2>
        <div class="cameras-grid" id="camerasList">
            <div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #868e96;">
                Нет активных камер. Создайте новую камеру.
            </div>
        </div>
    </div>

    <div id="notification" class="notification hidden"></div>

    <script>
        // Глобальные переменные
        let selectedVideo = null;
        let refreshInterval;
        let previewIntervals = {};

        // Инициализация при загрузке
        document.addEventListener('DOMContentLoaded', function() {
            loadStatus();
            loadVideos();
            loadCameras();
            
            // Обновление статуса каждые 5 секунд
            refreshInterval = setInterval(() => {
                loadStatus();
                loadCameras();
            }, 5000);
        });

        // Загрузка статуса
        function loadStatus() {
            fetch('/api/status')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('serverStatus').textContent = 'Работает';
                    document.getElementById('serverVersion').textContent = data.version || '0.4';
                })
                .catch(error => {
                    document.getElementById('serverStatus').textContent = 'Ошибка';
                    console.error('Error loading status:', error);
                });
        }

        // Загрузка списка видео
        function loadVideos() {
            fetch('/api/videos')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        updateVideoList(data.videos);
                        updateVideoSelect(data.videos);
                        document.getElementById('videosCount').textContent = data.videos.length;
                    }
                })
                .catch(error => {
                    console.error('Error loading videos:', error);
                });
        }

        // Обновление списка видео
        function updateVideoList(videos) {
            const videoList = document.getElementById('videoList');
            
            if (videos.length === 0) {
                videoList.innerHTML = '<div style="text-align: center; padding: 20px; color: #868e96;">Нет видеофайлов. Загрузите видео.</div>';
                return;
            }

            let html = '';
            videos.forEach(video => {
                html += `
                    <div class="video-item" onclick="selectVideo('${video.name}')" id="video-${video.name.replace(/[^a-zA-Z0-9]/g, '_')}">
                        <span class="video-name">${video.name}</span>
                        <span class="video-size">${video.size}</span>
                    </div>
                `;
            });
            videoList.innerHTML = html;
        }

        // Обновление выпадающего списка видео
        function updateVideoSelect(videos) {
            const select = document.getElementById('videoSelect');
            let options = '<option value="">Выберите видеофайл</option>';
            
            videos.forEach(video => {
                options += `<option value="${video.name}">${video.name} (${video.size})</option>`;
            });
            
            select.innerHTML = options;
        }

        // Выбор видео
        function selectVideo(videoName) {
            // Снимаем выделение со всех
            document.querySelectorAll('.video-item').forEach(el => {
                el.classList.remove('selected');
            });
            
            // Выделяем выбранное
            const safeName = videoName.replace(/[^a-zA-Z0-9]/g, '_');
            const selectedEl = document.getElementById(`video-${safeName}`);
            if (selectedEl) {
                selectedEl.classList.add('selected');
            }
            
            // Выбираем в выпадающем списке
            const select = document.getElementById('videoSelect');
            select.value = videoName;
            
            selectedVideo = videoName;
        }

        // Загрузка видео
        function uploadVideo(input) {
            const file = input.files[0];
            if (!file) return;

            const formData = new FormData();
            formData.append('video', file);

            showNotification('Загрузка...', 'info');

            fetch('/api/upload', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('✅ Видео загружено', 'success');
                    loadVideos();
                } else {
                    showNotification('❌ Ошибка: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showNotification('❌ Ошибка загрузки', 'error');
                console.error('Error uploading:', error);
            });

            // Очищаем input
            input.value = '';
        }

        // Поиск видео
        document.getElementById('videoSearch').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const items = document.querySelectorAll('.video-item');
            
            items.forEach(item => {
                const text = item.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
        });

        // Создание камеры
        function createCamera() {
            const cameraName = document.getElementById('cameraName').value;
            const videoFile = document.getElementById('videoSelect').value;
            const rtspPort = document.getElementById('rtspPort').value;
            const onvifPort = document.getElementById('onvifPort').value;
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;

            if (!videoFile) {
                showNotification('❌ Выберите видеофайл', 'error');
                return;
            }

            const data = {
                name: cameraName,
                video: `/app/videos/${videoFile}`,
                rtsp_port: parseInt(rtspPort),
                onvif_port: parseInt(onvifPort),
                username: username,
                password: password
            };

            showNotification('Создание камеры...', 'info');

            fetch('/api/cameras', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('✅ Камера создана', 'success');
                    loadCameras();
                } else {
                    showNotification('❌ Ошибка: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showNotification('❌ Ошибка создания', 'error');
                console.error('Error creating camera:', error);
            });
        }

        // Загрузка списка камер
        function loadCameras() {
            fetch('/api/cameras')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        updateCamerasList(data.cameras);
                        document.getElementById('camerasCount').textContent = data.cameras.length;
                    }
                })
                .catch(error => {
                    console.error('Error loading cameras:', error);
                });
        }

        // Обновление списка камер (НОВАЯ ВЕРСИЯ)
        function updateCamerasList(cameras) {
            const camerasList = document.getElementById('camerasList');
            
            if (cameras.length === 0) {
                camerasList.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; color: #868e96;">Нет активных камер. Создайте новую камеру.</div>';
                return;
            }

            let html = '';
            cameras.forEach(camera => {
                const statusClass = `camera-status status-${camera.status}`;
                const statusText = camera.status === 'running' ? 'Работает' : 
                                  camera.status === 'created' ? 'Создана' : 'Остановлена';
                
                // Добавляем timestamp чтобы изображение обновлялось
                const timestamp = new Date().getTime();
                
                html += `
                    <div class="camera-card" id="camera-${camera.id}">
                        <div class="camera-header">
                            <span class="camera-name">${camera.name}</span>
                            <span class="${statusClass}">${statusText}</span>
                        </div>
                        
                        ${camera.status === 'running' ? `
                            <div class="preview-container">
                                <img id="preview-${camera.id}" 
                                     src="/api/cameras/${camera.id}/snapshot?t=${timestamp}" 
                                     alt="Live Preview"
                                     onload="this.style.opacity='1';"
                                     onerror="this.src='data:image/svg+xml;base64,'">
                                <div class="live-badge">LIVE</div>
                                <div class="stream-info">
                                    ${camera.stream_info?.width || '?'}x${camera.stream_info?.height || '?'} | 
                                    ${camera.stream_info?.fps?.toFixed(1) || '?'} fps | 
                                    📊 ${camera.stream_info?.frames_sent || 0} кадров
                                </div>
                            </div>
                        ` : ''}
                        
                        <div class="camera-details">
                            <div class="detail-item">
                                <span class="detail-label">📷 ID:</span>
                                <span class="detail-value">${camera.id}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">🏭 Модель:</span>
                                <span class="detail-value">${camera.manufacturer || 'Unknown'} ${camera.model || ''}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">🎬 Видео:</span>
                                <span class="detail-value">${camera.video || 'Нет'}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">🔌 RTSP порт:</span>
                                <span class="detail-value">${camera.rtsp_port}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">🌐 ONVIF порт:</span>
                                <span class="detail-value">${camera.onvif_port}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">👤 Логин:</span>
                                <span class="detail-value">${camera.username}</span>
                            </div>
                        </div>
                        
                        ${camera.status === 'running' ? `
                            <div class="url-box">
                                <div><strong>📡 RTSP URL:</strong></div>
                                <div style="background: white; padding: 8px; border-radius: 5px; margin-top: 5px; font-family: monospace;">
                                    rtsp://${camera.username}:${camera.password}@${window.location.hostname}:${camera.rtsp_port}/live
                                </div>
                                <div style="margin-top: 8px;"><strong>🔗 ONVIF:</strong></div>
                                <div style="background: white; padding: 8px; border-radius: 5px; margin-top: 5px; font-family: monospace;">
                                    http://${window.location.hostname}:${camera.onvif_port}/onvif/device_service
                                </div>
                            </div>
                        ` : ''}
                        
                        <div class="camera-actions">
                            ${camera.status === 'running' ? 
                                `<button class="btn btn-sm btn-danger" onclick="stopCamera('${camera.id}')">⏹ Остановить</button>` : 
                                `<button class="btn btn-sm btn-success" onclick="startCamera('${camera.id}')">▶ Запустить</button>`
                            }
                            <button class="btn btn-sm btn-secondary" onclick="deleteCamera('${camera.id}')">🗑 Удалить</button>
                        </div>
                    </div>
                `;
            });
            
            camerasList.innerHTML = html;
            
            // Запускаем обновление превью для работающих камер
            cameras.forEach(camera => {
                if (camera.status === 'running') {
                    startPreviewRefresh(camera.id);
                }
            });
        }

        // Функция для обновления превью
        function startPreviewRefresh(cameraId) {
            // Очищаем старый интервал если был
            if (previewIntervals[cameraId]) {
                clearInterval(previewIntervals[cameraId]);
            }
            
            // Запускаем новый интервал (обновление каждые 500ms)
            previewIntervals[cameraId] = setInterval(() => {
                const img = document.getElementById(`preview-${cameraId}`);
                if (img) {
                    const timestamp = new Date().getTime();
                    img.src = `/api/cameras/${cameraId}/snapshot?t=${timestamp}`;
                }
            }, 500);
        }

        // Запуск камеры
        function startCamera(cameraId) {
            fetch(`/api/cameras/${cameraId}/start`, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('✅ Камера запущена', 'success');
                    loadCameras();
                } else {
                    showNotification('❌ Ошибка: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showNotification('❌ Ошибка запуска', 'error');
                console.error('Error starting camera:', error);
            });
        }

        // Остановка камеры
        function stopCamera(cameraId) {
            fetch(`/api/cameras/${cameraId}/stop`, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('⏹ Камера остановлена', 'success');
                    // Очищаем интервал превью
                    if (previewIntervals[cameraId]) {
                        clearInterval(previewIntervals[cameraId]);
                        delete previewIntervals[cameraId];
                    }
                    loadCameras();
                } else {
                    showNotification('❌ Ошибка: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showNotification('❌ Ошибка остановки', 'error');
                console.error('Error stopping camera:', error);
            });
        }

        // Удаление камеры
        function deleteCamera(cameraId) {
            if (!confirm('Вы уверены, что хотите удалить камеру?')) return;
            
            fetch(`/api/cameras/${cameraId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('🗑 Камера удалена', 'success');
                    // Очищаем интервал превью
                    if (previewIntervals[cameraId]) {
                        clearInterval(previewIntervals[cameraId]);
                        delete previewIntervals[cameraId];
                    }
                    loadCameras();
                } else {
                    showNotification('❌ Ошибка: ' + data.error, 'error');
                }
            })
            .catch(error => {
                showNotification('❌ Ошибка удаления', 'error');
                console.error('Error deleting camera:', error);
            });
        }

        // Показ уведомлений
        function showNotification(message, type) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.className = `notification ${type}`;
            notification.classList.remove('hidden');
            
            setTimeout(() => {
                notification.classList.add('hidden');
            }, 3000);
        }

        // Очистка интервалов при выгрузке страницы
        window.addEventListener('beforeunload', function() {
            for (let cameraId in previewIntervals) {
                clearInterval(previewIntervals[cameraId]);
            }
        });
    </script>
</body>
</html>
